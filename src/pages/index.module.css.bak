/* ═══════════════════════════════════════════════════════════════
   WELLEX — Strict Apple-Level Design System
   Pure Black · White · Silver · No Gold
   ═══════════════════════════════════════════════════════════════ */

/* ─── Hero ──────────────────────────────────────────────────────── */
.hero {
  position: relative;
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  overflow: hidden;
  background: #0F1A2E;
  padding: 80px 24px 64px;
}

.hero::before {
  content: '';
  position: absolute;
  width: 700px;
  height: 700px;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -55%);
  background: radial-gradient(ellipse,
    rgba(255,255,255,0.04) 0%,
    transparent 68%
  );
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

.heroBg {
  position: absolute;
  inset: 0;
  background: #0F1A2E;
  z-index: 0;
}

.heroInner {
  position: relative;
  z-index: 2;
  max-width: 780px;
  margin: 0 auto;
  padding: 0;
}

.heroBadge {
  display: inline-block;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.38);
  border: 1px solid rgba(255,255,255,0.12);
  padding: 5px 16px;
  border-radius: 100px;
  margin-bottom: 28px;
  background: transparent;
}

.heroTitle {
  font-size: clamp(52px, 9vw, 96px);
  font-weight: 600;
  letter-spacing: -0.025em;
  color: #FFFFFF;
  margin: 0 0 0;
  line-height: 1;
}

.heroTitleAccent {
  color: #FFFFFF;
  font-weight: 600;
}

.heroSubtitle {
  font-size: clamp(14px, 2vw, 17px);
  color: rgba(255,255,255,0.42);
  letter-spacing: 0.01em;
  margin: 18px auto 44px;
  font-weight: 400;
  max-width: 500px;
  line-height: 1.65;
}

/* Stats row */
.heroStats {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 44px;
  gap: 0;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 36px;
}

.statNum {
  font-size: 36px;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
  letter-spacing: -0.03em;
}

.statLabel {
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.32);
  margin-top: 6px;
  font-weight: 500;
}

.statDivider {
  width: 1px;
  height: 36px;
  background: rgba(255,255,255,0.1);
}

/* Buttons */
.heroButtons {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
}

.btnPrimary {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  background: #FFFFFF;
  color: #000000 !important;
  font-weight: 600;
  font-size: 13.5px;
  letter-spacing: -0.01em;
  padding: 13px 28px;
  border-radius: 100px;
  text-decoration: none !important;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  border: none;
}

.btnPrimary:hover {
  background: rgba(255,255,255,0.88);
  transform: translateY(-1px);
  text-decoration: none !important;
  color: #000000 !important;
}

.btnSecondary {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  background: transparent;
  color: rgba(255,255,255,0.75) !important;
  font-weight: 500;
  font-size: 13.5px;
  letter-spacing: -0.01em;
  padding: 13px 28px;
  border-radius: 100px;
  text-decoration: none !important;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1px solid rgba(255,255,255,0.2);
}

.btnSecondary:hover {
  border-color: rgba(255,255,255,0.5);
  color: #FFFFFF !important;
  transform: translateY(-1px);
  text-decoration: none !important;
}

/* Scroll hint */
.scrollHint {
  position: absolute;
  bottom: 28px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0.25;
  animation: fadeUpDown 2.5s ease-in-out infinite;
}

.scrollLine {
  width: 1px;
  height: 36px;
  background: linear-gradient(180deg, transparent, rgba(255,255,255,0.7), transparent);
}

@keyframes fadeUpDown {
  0%, 100% { opacity: 0.2; transform: translateX(-50%) translateY(0); }
  50%       { opacity: 0.4; transform: translateX(-50%) translateY(5px); }
}

/* ─── Main ──────────────────────────────────────────────────────── */
.main {
  background: #0F1A2E;
  padding: 0 0 80px;
}

.section {
  max-width: 1100px;
  margin: 0 auto;
  padding: 64px 32px 0;
}

.sectionLabel {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.28);
  margin-bottom: 8px;
}

.sectionTitle {
  font-size: clamp(22px, 3vw, 30px);
  font-weight: 600;
  letter-spacing: -0.025em;
  color: #FFFFFF;
  margin-bottom: 32px;
  line-height: 1.15;
}

.sectionTitle::after {
  content: '';
  display: block;
  width: 32px;
  height: 1px;
  background: rgba(255,255,255,0.25);
  margin-top: 14px;
}

/* ─── Quick Links Grid ──────────────────────────────────────────── */
.quickGrid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: rgba(255,255,255,0.07);
  border-radius: 16px;
  overflow: hidden;
}

.quickCard {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  padding: 22px 20px;
  background: #0F1A2E;
  text-decoration: none !important;
  transition: background 0.2s ease;
  color: inherit;
  position: relative;
}

.quickCard:first-child {
  border-radius: 16px 0 0 0;
}
.quickCard:nth-child(3) {
  border-radius: 0 16px 0 0;
}
.quickCard:nth-child(4) {
  border-radius: 0 0 0 16px;
}
.quickCard:last-child {
  border-radius: 0 0 16px 0;
}

.quickCard:hover {
  background: #162235;
  text-decoration: none !important;
}

.quickIconWrap {
  flex-shrink: 0;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  background: rgba(255,255,255,0.06);
}

.quickLabel {
  font-size: 13.5px;
  font-weight: 600;
  color: rgba(255,255,255,0.88);
  margin-bottom: 4px;
  letter-spacing: -0.01em;
}

.quickDesc {
  font-size: 12px;
  color: rgba(255,255,255,0.35);
  line-height: 1.5;
  font-weight: 400;
}

/* ─── Category Grid ─────────────────────────────────────────────── */
.catGrid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 1px;
  background: rgba(255,255,255,0.07);
  border-radius: 16px;
  overflow: hidden;
}

.catCard {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 24px 12px 20px;
  background: #0F1A2E;
  text-decoration: none !important;
  transition: background 0.2s ease;
  text-align: center;
  color: inherit;
}

.catCard:hover {
  background: #162235;
  text-decoration: none !important;
}

.catIconWrap {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10px;
  background: rgba(255,255,255,0.06);
  transition: background 0.2s ease;
}

.catCard:hover .catIconWrap {
  background: rgba(255,255,255,0.1);
}

.catLabel {
  font-size: 12px;
  font-weight: 600;
  color: rgba(255,255,255,0.75);
  letter-spacing: -0.01em;
  line-height: 1.3;
}

.catCount {
  font-size: 10px;
  color: rgba(255,255,255,0.28);
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

/* ─── Badge Strip ───────────────────────────────────────────────── */
.badgeStrip {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: center;
  padding: 48px 32px 0;
  max-width: 1100px;
  margin: 0 auto;
}

.badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.3);
  border: 1px solid rgba(255,255,255,0.08);
  padding: 6px 14px;
  border-radius: 100px;
  background: transparent;
  transition: all 0.2s ease;
}

.badge:hover {
  border-color: rgba(255,255,255,0.2);
  color: rgba(255,255,255,0.55);
}

/* ─── Divider ───────────────────────────────────────────────────── */
.divider {
  height: 1px;
  background: rgba(255,255,255,0.07);
  max-width: 1100px;
  margin: 0 auto;
}

/* ─── Responsive ─────────────────────────────────────────────────── */
@media (max-width: 1024px) {
  .quickGrid {
    grid-template-columns: repeat(2, 1fr);
  }
  .catGrid {
    grid-template-columns: repeat(4, 1fr);
  }
}

@media (max-width: 768px) {
  .hero {
    min-height: auto;
    padding: 64px 24px 52px;
  }

  .stat {
    padding: 0 20px;
  }

  .quickGrid {
    grid-template-columns: 1fr;
  }

  .catGrid {
    grid-template-columns: repeat(3, 1fr);
  }

  .section {
    padding: 48px 20px 0;
  }
}

@media (max-width: 480px) {
  .heroStats {
    gap: 0;
  }

  .stat {
    padding: 0 14px;
  }

  .statNum {
    font-size: 28px;
  }

  .catGrid {
    grid-template-columns: repeat(2, 1fr);
  }
}
